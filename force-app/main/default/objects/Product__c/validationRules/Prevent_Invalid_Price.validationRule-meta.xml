<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Prevent_Invalid_Price</fullName>
    <active>true</active>
    <description>Ensures the unit price is greater than zero.</description>
    <errorConditionFormula>Unit_Price__c  &lt;= 0</errorConditionFormula>
    <errorDisplayField>Unit_Price__c</errorDisplayField>
    <errorMessage>Unit price must be greater than zero.</errorMessage>
</ValidationRule>
